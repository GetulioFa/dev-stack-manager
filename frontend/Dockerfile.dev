# Dockerfile.dev — Angular CLI dev server com hot-reload
FROM node:22-alpine
WORKDIR /app

COPY package.json package-lock.json ./
RUN npm ci

COPY . .

EXPOSE 4200

# ng serve aponta para o backend no Docker Compose via variável de ambiente
# O proxy.conf.json em dev local aponta para localhost:5000;
# no Docker Compose, o backend é acessível como "backend:8080"
CMD ["npx", "ng", "serve", "--host", "0.0.0.0", "--port", "4200", \
     "--proxy-config", "proxy.conf.docker.json"]
